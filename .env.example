# LLM provider: DeepSeek OpenAI-compatible API
DEEPSEEK_API_KEY=replace-with-your-api-key
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# Local datastore defaults match compose.yaml
DATABASE_URL=postgresql://admin:password123@localhost:5432/agentflow_db
REDIS_URL=redis://localhost:6379/0

# API security and browser access
# Leave API_KEYS empty only for local development.
API_KEYS=local-dev-key
CORS_ALLOW_ORIGINS=http://localhost:8501,http://127.0.0.1:8501
JWT_SECRET=replace-with-a-long-random-secret
JWT_REFRESH_EXPIRES_SECONDS=2592000
APP_ENV=development
UVICORN_RELOAD=false

# Frontend
AGENTFLOW_API_BASE_URL=http://127.0.0.1:8000

# Production compose
POSTGRES_USER=admin
POSTGRES_PASSWORD=password123
POSTGRES_DB=agentflow_db
REDIS_PASSWORD=replace-with-strong-redis-password
PUBLIC_APP_ORIGIN=http://localhost:8501
PUBLIC_API_BASE_URL=http://localhost:8000
ESTIMATED_COST_USD_PER_1K=0.002
